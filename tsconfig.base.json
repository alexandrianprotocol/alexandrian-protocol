{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@alexandrian/protocol": ["packages/protocol/dist"],
      "@alexandrian/sdk-core": ["packages/sdk-core/dist"],
      "@alexandrian/sdk-adapters": ["packages/sdk-adapters/dist"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
