# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Comma-separated API keys. Generate with: openssl rand -hex 32
# Format: key1,key2,key3
API_KEYS=

# ── Subgraph (The Graph) ───────────────────────────────────────────────────────
# The Graph hosted service or decentralised network endpoint for the Alexandrian subgraph
SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/YOUR_ORG/alexandrian-base

# ── IPFS ──────────────────────────────────────────────────────────────────────
# Gateway used to resolve IPFS CIDs into KB artifacts.
# Match this to whichever provider you used in bundle-artifacts.mjs:
#
#   Pinata (free tier):      https://gateway.pinata.cloud/ipfs
#   web3.storage / Storacha: https://w3s.link/ipfs
#   Cloudflare (public):     https://cloudflare-ipfs.com/ipfs
IPFS_GATEWAY=https://w3s.link/ipfs

# ── Contract ──────────────────────────────────────────────────────────────────
CONTRACT_ADDRESS=0x5D6dee4BB3E70f3e8118223Bf297B2eEdBC5B000
RPC_URL=https://mainnet.base.org

# ── Rate limiting (requests per minute per API key) ───────────────────────────
RATE_LIMIT_FREE=60
RATE_LIMIT_PRO=600
RATE_LIMIT_ENTERPRISE=6000
