# Base mainnet (deploy / write). Copy to .env and fill in.
# BASE_MAINNET_RPC_URL=https://mainnet.base.org
# DEPLOYER_PRIVATE_KEY=0x...   <- 66 chars (0x + 64 hex). NOT your wallet address (42 chars). Export from MetaMask/Coinbase Wallet.
# ALLOW_MAINNET_DEPLOY=true    <- required to run deploy or write commands
# BASESCAN_API_KEY=            <- optional, for contract verification

# Base Sepolia (testing)
# BASE_SEPOLIA_RPC_URL=
# PRIVATE_KEY=0x...            <- 66 chars, test wallet
