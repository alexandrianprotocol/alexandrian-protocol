{
  "name": "@alexandrian/sdk-adapters",
  "version": "0.2.0",
  "description": "Alexandrian Protocol — SDK adapters and product-layer integrations",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./adapters/langchain": {
      "import": "./dist/lib/adapters/langchain.js",
      "types": "./dist/lib/adapters/langchain.d.ts"
    },
    "./adapters/llamaindex": {
      "import": "./dist/lib/adapters/llamaindex.js",
      "types": "./dist/lib/adapters/llamaindex.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "build:types": "tsc --emitDeclarationOnly",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "benchmark": "tsx scripts/benchmark.ts",
    "benchmark:verbose": "tsx scripts/benchmark.ts --verbose"
  },
  "dependencies": {
    "@alexandrian/protocol": "workspace:*",
    "@alexandrian/sdk-core": "workspace:*",
    "ethers": "^6.8.0",
    "node-fetch": "^3.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": false
    }
  }
}
