# ── Alexandrian Generator — Environment Variables ─────────────────────────────
#
# Copy this file to .env and fill in your values before running the pipeline.
#
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for: AI seed generation (Phase 1b), derived KB synthesis (Phase 2),
#               expansion (Phase 3), upgrade-seeds-pipeline transformation.
# Get from: https://platform.openai.com/api-keys

OPENAI_API_KEY=

# Optional: override the model used for seed upgrade/generation.
# Default: gpt-4o (upgrade step), gpt-4o (generation step)
# Fallback: gpt-4o-mini (on primary failure)
# Set to gpt-4o-mini to reduce cost during testing (~10× cheaper).
# OPENAI_UPGRADE_MODEL=gpt-4o
# OPENAI_GENERATION_MODEL=gpt-4o


# ── IPFS / Pinata ─────────────────────────────────────────────────────────────
# Required for: publish.mjs (pins artifact to IPFS before on-chain publish).
# Get from: https://pinata.cloud → API Keys → New Key → Admin permissions

# Option A: JWT (preferred — single credential, admin scope)
PINATA_JWT=

# Option B: API Key + Secret (legacy)
# PINATA_API_KEY=
# PINATA_SECRET_API_KEY=


# ── Base Mainnet — Publisher Wallet ───────────────────────────────────────────
# Required for: publish.mjs (signs publishKB transactions on Base mainnet).
# This wallet ONLY needs gas — no stake required during bootstrap mode
# (after setMinStake(0) is called on the contract).
#
# Balance needed: ~0.05 ETH on Base (~$150 at 3k ETH) covers 10k publishes
# at ~150k gas each (~$0.003/tx at current Base gas prices).
#
# WARNING: Never use a wallet that holds significant ETH for this role.
#          Generate a dedicated publisher wallet and fund it with exactly
#          what's needed for the run.

OWNER_PRIVATE_KEY=

# Optional: use DEPLOYER_PRIVATE_KEY as fallback (legacy alias)
# DEPLOYER_PRIVATE_KEY=


# ── Redis / Upstash (optional) ────────────────────────────────────────────────
# Used by: sdk-adapters enhanceQuery() for KB metadata caching.
# Not required for the generator pipeline itself — only for the SaaS/SDK layer.
# Get from: https://upstash.com → Create Database → REST API

# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=


# ── Base RPC ──────────────────────────────────────────────────────────────────
# Optional: override the Base mainnet RPC endpoint.
# Default: https://mainnet.base.org (public endpoint, rate-limited).
# For the 10k run, use a private RPC (Alchemy, QuickNode) to avoid rate limits.
# Get from: https://www.alchemy.com or https://www.quicknode.com

# BASE_RPC_URL=https://mainnet.base.org


# ── Pipeline Run Checklist ────────────────────────────────────────────────────
#
# Before running npm run publish, verify:
#   [ ] OWNER_PRIVATE_KEY wallet has >= 0.05 ETH on Base mainnet
#   [ ] PINATA_JWT is valid (test: curl -H "Authorization: Bearer $PINATA_JWT" https://api.pinata.cloud/data/testAuthentication)
#   [ ] OPENAI_API_KEY is valid with sufficient credits for ~1000 generations
#   [ ] setMinStake(0) has been called on contract 0xD1F216E872a9ed4b90E364825869c2F377155B29
#
# Run order:
#   npm run build
#   node scripts/inject-handcrafted-kbs.mjs       # 22 anchor KBs → staging/refined/
#   npm run generate:1k-ai                         # fills staging/pending/ (~1000 KBs)
#   npm run publish:dry                            # dry-run to verify before committing
#   npm run publish                                # live publish to Base mainnet
