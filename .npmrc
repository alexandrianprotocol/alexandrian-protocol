engine-strict=true
save-exact=true

# Hardhat + hardhat-ethers require hoisting for module resolution (hardhat/types/network)
public-hoist-pattern[]=*hardhat*
public-hoist-pattern[]=*hardhat-ethers*
# graph-cli resolves modules from CWD; hoist so subgraph build finds them
public-hoist-pattern[]=*graphprotocol*
