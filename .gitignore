# Dependencies
node_modules/
.pnpm-store/

# Build outputs (rebuilt by pnpm verify / pnpm build)
dist/
build/
artifacts/
cache/
typechain-types/

# Test coverage
coverage/

# TypeScript incremental build info
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Environment / secrets — NEVER commit
.env
.env.*
!.env.example

# Generator staging queue — KB JSON files (not committed; .gitkeep preserves dirs)
packages/generator/staging/pending/*.json
packages/generator/staging/refined/*.json
packages/generator/staging/marginal/*.json
packages/generator/staging/failed/*.json
packages/generator/staging/published/*.json
packages/generator/staging/bundled/*.json
packages/generator/staging/*.jsonl
packages/generator/staging/preview/
packages/generator/staging/bundles-local/
packages/generator/staging/bundled-local/
packages/generator/staging/documentation/
packages/generator/staging/reports/
packages/generator/staging/ontology.json

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
.claude/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel
